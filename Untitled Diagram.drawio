        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph TD\n    %% Define Styles to match the image style\n    classDef startEnd fill:#d1fae5,stroke:#059669,stroke-width:2px,color:#065f46,rx:20px;\n    classDef blueBox fill:#dbeafe,stroke:#3b82f6,stroke-width:1.5px,color:#1e3a8a;\n    classDef decision fill:#fef3c7,stroke:#d97706,stroke-width:1.5px,color:#78350f;\n    classDef error fill:#fee2e2,stroke:#ef4444,stroke-width:1.5px,color:#991b1b;\n    classDef purpleBox fill:#ede9fe,stroke:#8b5cf6,stroke-width:1.5px,color:#5b21b6;\n    classDef greenBox fill:#ecfdf5,stroke:#10b981,stroke-width:1.5px,color:#065f46;\n    classDef orangeBox fill:#ffedd5,stroke:#f97316,stroke-width:1.5px,color:#7c2d12;\n\n    %% Flow Nodes\n    Start([START]):::startEnd\n    OpenApp[Open TrackHub Nepal Website]:::blueBox\n    ShowStats[Display Net Balance &amp; Stats Bar]:::blueBox\n    SelectTab{Select a Tab?}:::decision\n    \n    %% Tab 1: Add Transaction &amp; Budget\n    TabAdd[➕ ADD TAB]:::purpleBox\n    InputTx[Input Amount, Date, Desc, Category, Payment Method]:::purpleBox\n    ValidTx{Is Input Valid?}:::decision\n    InvalidTx[Show Toast: Enter Valid Details]:::error\n    SaveTx[Save Transaction in Arrays &amp; Update Balance]:::purpleBox\n    SetBudget[Set Monthly Budget Limit]:::purpleBox\n\n    %% Tab 2 &amp; 3: Views\n    TabTx[📋 TRANSACTIONS TAB]:::blueBox\n    SearchTx[Search or Delete Transactions]:::blueBox\n    TabBudget[🎯 BUDGET TAB]:::greenBox\n    ViewProgress[View Budget Progress &amp; Overspend Bars]:::greenBox\n\n    %% Tab 4 &amp; 5: Analysis\n    TabSummary[📊 SUMMARY TAB]:::orangeBox\n    ViewInsights[View Biggest Expense, Daily Avg &amp; Category Bars]:::orangeBox\n    TabReport[📈 REPORT TAB]:::orangeBox\n    ViewReport[View 50/30/20 Rule Analysis &amp; Smart Tips]:::orangeBox\n\n    End([END]):::startEnd\n\n    %% Connection Logic\n    Start --&gt; OpenApp\n    OpenApp --&gt; ShowStats\n    ShowStats --&gt; SelectTab\n    \n    %% Branching to Tabs\n    SelectTab --&gt;|Add Tab| TabAdd\n    SelectTab --&gt;|Transactions Tab| TabTx\n    SelectTab --&gt;|Budget Tab| TabBudget\n    SelectTab --&gt;|Summary/Report Tabs| TabSummary\n\n    %% Tab 1 Path\n    TabAdd --&gt; InputTx\n    InputTx --&gt; ValidTx\n    ValidTx --&gt;|No| InvalidTx\n    InvalidTx --&gt; InputTx\n    ValidTx --&gt;|Yes| SaveTx\n    TabAdd --&gt; SetBudget\n    \n    %% Tab 2 Path\n    TabTx --&gt; SearchTx\n    \n    %% Tab 3 Path\n    TabBudget --&gt; ViewProgress\n    \n    %% Tab 4/5 Path\n    TabSummary --&gt; ViewInsights\n    TabSummary --&gt; TabReport\n    TabReport --&gt; ViewReport\n\n    %% Consolidation to End\n    SaveTx --&gt; End\n    SetBudget --&gt; End\n    SearchTx --&gt; End\n    ViewProgress --&gt; End\n    ViewInsights --&gt; End\n    ViewReport --&gt; End&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="wpQ6fqGbBduA0wTkjezp-94">
